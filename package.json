{
  "name": "@webenvoy/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "build": "pnpm -r build",
    "conformance": "pnpm --filter @webenvoy/core-runtime build && pnpm --filter @webenvoy/conformance test",
    "smoke": "pnpm --filter @webenvoy/conformance smoke",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm build && pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^5.9.3"
  }
}
