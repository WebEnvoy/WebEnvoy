{
  "name": "@webenvoy/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm --filter @webenvoy/core-runtime build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @webenvoy/core-runtime build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node dist/self-check.js && node dist/runtime-process-self-check.js",
    "lint": "pnpm --filter @webenvoy/core-runtime build && tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@webenvoy/core-runtime": "workspace:*"
  }
}
