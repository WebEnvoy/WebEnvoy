{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.webenvoy.dev/core/run-record.v0.schema.json",
  "title": "WebEnvoy Core Run Record v0",
  "type": "object",
  "additionalProperties": false,
  "x-webenvoy": {
    "owner": "Core Run Record",
    "status": "accepted-v0",
    "schema_version": "webenvoy.run-record.v0",
    "compatibility_boundary": "Run status is monotonic. Optional refs may be added, but terminal states, ref owner boundaries, and raw-material exclusions require an ADR or pending-decision update.",
    "source_adrs": [
      "docs/adr/0003-result-envelope-and-run-record.md",
      "docs/adr/0005-task-intent-and-run-lifecycle-v0.md",
      "docs/adr/0007-reference-version-ownership-v0.md",
      "docs/adr/0008-core-technical-architecture-baseline.md"
    ],
    "field_owners": {
      "run_id": "Core",
      "status": "Core",
      "task_intent_ref": "Core",
      "capability_ref": "Lode owns referenced capability",
      "capability_version": "Lode owns referenced capability version",
      "capability_source_ref": "Lode owns referenced catalog/package source",
      "capability_lock_ref": "Lode owns referenced package lock",
      "scope_target_ref": "Caller declares; Core validates, normalizes, and records the exact target used for runtime admission",
      "runtime_binding_refs": "Harbor owns referenced runtime facts",
      "result_ref": "Core",
      "result_outcome": "Core",
      "public_result_summary": "Core persists a bounded public projection after runtime private-field rejection",
      "projection_ref": "Core",
      "source_refs": "Harbor or Lode owns referenced source body; Core records refs only",
      "preview_result": "Core projected validate-only preview result; submitted result truth is out of boundary",
      "evidence_refs": "Harbor or evidence producer owns ref body; Core records refs only",
      "authorization_decision_refs": "Core owns referenced Authorization Decision summaries",
      "failure": "Core"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "status",
    "created_at",
    "updated_at",
    "task_intent_ref",
    "capability_ref",
    "admission"
  ],
  "properties": {
    "schema_version": {
      "const": "webenvoy.run-record.v0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "admitted",
        "running",
        "succeeded",
        "failed",
        "blocked",
        "requires_user_action",
        "manual_recovery_required",
        "unknown_outcome",
        "cancelled",
        "expired"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "terminal_at": {
      "type": "string",
      "format": "date-time"
    },
    "task_intent_ref": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint_ref": {
      "type": "string",
      "minLength": 1
    },
    "capability_ref": {
      "type": "string",
      "minLength": 1
    },
    "capability_version": {
      "type": "string",
      "minLength": 1
    },
    "capability_source_ref": {
      "type": "string",
      "minLength": 1
    },
    "capability_lock_ref": {
      "type": "string",
      "minLength": 1
    },
    "package_ref": {
      "type": "string",
      "minLength": 1
    },
    "scope_target_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "format": "webenvoy-stored-target-ref",
      "description": "The normalized non-sensitive task target. Runtime URL tasks use this exact value for Harbor session launch and operation dispatch."
    },
    "admission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "action_risk"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["accepted", "accepted_with_warnings", "blocked_pre_admission", "requires_user_action", "deferred_true_write"]
        },
        "action_risk": {
          "type": "string",
          "enum": ["read", "write", "submit", "destructive"]
        },
        "resource_requirement_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "runtime_binding_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "resource_match_ref": {
          "type": "string",
          "minLength": 1
        },
        "runtime_session_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "identity_environment_ref",
            "execution_identity_ref",
            "runtime_session_ref",
            "profile_ref",
            "provider_ref",
            "provider_mode",
            "lifecycle_state",
            "control_owner",
            "session_use",
            "core_task_run",
            "consumer_boundary"
          ],
          "properties": {
            "schema_version": {
              "const": "webenvoy.runtime-session-binding.v0"
            },
            "identity_environment_ref": {
              "type": "string",
              "minLength": 1
            },
            "execution_identity_ref": {
              "type": "string",
              "minLength": 1
            },
            "runtime_session_ref": {
              "type": "string",
              "minLength": 1
            },
            "profile_ref": {
              "type": "string",
              "minLength": 1
            },
            "provider_ref": {
              "type": "string",
              "minLength": 1
            },
            "provider_mode": {
              "type": "string",
              "minLength": 1
            },
            "lifecycle_state": {
              "type": "string",
              "minLength": 1
            },
            "control_owner": {
              "type": "string",
              "minLength": 1
            },
            "session_use": {
              "type": "string",
              "enum": ["manual_browsing", "agent_direct_browsing", "direct_session", "core_task_run"]
            },
            "core_task_run": {
              "const": true
            },
            "consumer_boundary": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "runtime_binding_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "action_request": {
      "$ref": "action-request.schema.json"
    },
    "approval_request": {
      "$ref": "approval-request.schema.json"
    },
    "result_ref": {
      "type": "string",
      "minLength": 1
    },
    "result_kind": {
      "type": "string",
      "minLength": 1
    },
    "result_outcome": {
      "type": "string",
      "enum": ["success", "partial", "empty"]
    },
    "output_schema_id": {
      "type": "string",
      "minLength": 1
    },
    "projection_ref": {
      "type": "string",
      "minLength": 1
    },
    "public_result_summary": {
      "type": "object"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preview_result": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "state", "submitted", "action_refs", "capability", "evidence_refs", "consumer_boundary"],
      "properties": {
        "schema_version": {"const": "webenvoy.preview-result.v0"},
        "state": {"type": "string", "enum": ["available", "preview_unavailable", "page_changed", "user_cancelled"]},
        "submitted": {"const": false},
        "failure_class": {"type": "string", "enum": ["preview_unavailable", "page_changed", "user_cancelled"]}
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authorization_decision_refs": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^authorization-decision:[a-f0-9]{32}:[a-f0-9]{32}$",
        "maxLength": 89
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "code", "phase", "recovery_hint"],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "request_invalid",
            "capability_contract",
            "resource_admission",
            "action_risk",
            "runtime_execution",
            "result_projection",
            "evidence_reference",
            "persistence_observability",
            "write_outcome"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": ["pre_admission", "admission", "resource_matching", "runtime_binding", "execution", "verification", "projection", "evidence", "persistence", "observability", "query", "write_verification", "reconciliation"]
        },
        "recovery_hint": {
          "type": "string",
          "minLength": 1
        },
        "attribution": {
          "type": "string",
          "enum": ["capability", "input", "runtime", "site", "evidence", "unknown"]
        }
      }
    },
    "post_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "status", "summary", "consumer_boundary"],
      "properties": {
        "schema_version": {
          "const": "webenvoy.post-check-result.v0"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "blocked", "not_run"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "attribution": {
          "type": "string",
          "enum": ["capability", "input", "runtime", "site", "evidence", "unknown"]
        },
        "recovery_hint": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "consumer_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "retention_state": {
      "type": "string",
      "enum": ["active", "summary_only", "expired", "redacted", "access_denied", "deleted_by_policy"]
    }
  }
}
