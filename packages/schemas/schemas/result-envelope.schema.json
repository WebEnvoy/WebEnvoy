{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.webenvoy.dev/core/result-envelope.v0.schema.json",
  "title": "WebEnvoy Core Result Envelope v0",
  "type": "object",
  "additionalProperties": false,
  "x-webenvoy": {
    "owner": "Core Result Projection",
    "status": "accepted-v0",
    "schema_version": "webenvoy.result-envelope.v0",
    "compatibility_boundary": "Result payload may add optional refs, public projections, and validate-only preview results. Raw runtime material, submitted results, failure taxonomy changes, and terminal outcome changes require an ADR or pending-decision update.",
    "source_adrs": [
      "docs/adr/0003-result-envelope-and-run-record.md",
      "docs/adr/0007-reference-version-ownership-v0.md",
      "docs/adr/0008-core-technical-architecture-baseline.md"
    ],
    "field_owners": {
      "run_record_ref": "Core",
      "result_ref": "Core",
      "capability_ref": "Lode owns referenced capability",
      "capability_version": "Lode owns referenced capability version",
      "capability_source_ref": "Lode owns referenced catalog/package source",
      "capability_lock_ref": "Lode owns referenced package lock",
      "package_ref": "Lode owns referenced package",
      "data": "Lode owns normalized public shape; Core validates projection",
      "raw_payload_refs": "Harbor or evidence producer owns raw payload body",
      "evidence_refs": "Harbor or evidence producer owns evidence body",
      "preview_result": "Core projects Lode expected change and Harbor preview evidence refs without submitted result truth",
      "failure": "Core"
    }
  },
  "required": [
    "schema_version",
    "run_record_ref",
    "ok",
    "outcome",
    "terminal",
    "capability_ref"
  ],
  "properties": {
    "schema_version": {
      "const": "webenvoy.result-envelope.v0"
    },
    "run_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "result_ref": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "empty",
        "failed",
        "blocked",
        "requires_user_action",
        "manual_recovery_required",
        "unknown_outcome",
        "cancelled"
      ]
    },
    "terminal": {
      "type": "boolean"
    },
    "result_kind": {
      "type": "string",
      "minLength": 1
    },
    "output_schema_id": {
      "type": "string",
      "minLength": 1
    },
    "capability_ref": {
      "type": "string",
      "minLength": 1
    },
    "capability_version": {
      "type": "string",
      "minLength": 1
    },
    "capability_source_ref": {
      "type": "string",
      "minLength": 1
    },
    "capability_lock_ref": {
      "type": "string",
      "minLength": 1
    },
    "package_ref": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "type": "object"
    },
    "projection_ref": {
      "type": "string",
      "minLength": 1
    },
    "raw_payload_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preview_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "state", "submitted", "action_refs", "capability", "evidence_refs", "consumer_boundary"],
      "properties": {
        "schema_version": {
          "const": "webenvoy.preview-result.v0"
        },
        "state": {
          "type": "string",
          "enum": ["available", "preview_unavailable", "page_changed", "user_cancelled"]
        },
        "submitted": {
          "const": false
        },
        "expected_change": {
          "type": "object"
        },
        "action_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action_request_id"],
          "properties": {
            "action_request_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "capability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["capability_ref"],
          "properties": {
            "capability_ref": {"type": "string", "minLength": 1},
            "capability_version": {"type": "string", "minLength": 1},
            "capability_source_ref": {"type": "string", "minLength": 1},
            "capability_lock_ref": {"type": "string", "minLength": 1},
            "package_ref": {"type": "string", "minLength": 1}
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "failure_class": {
          "type": "string",
          "enum": ["preview_unavailable", "page_changed", "user_cancelled"]
        },
        "consumer_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "code", "phase", "recovery_hint"],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "request_invalid",
            "capability_contract",
            "resource_admission",
            "action_risk",
            "runtime_execution",
            "result_projection",
            "evidence_reference",
            "persistence_observability",
            "write_outcome"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": ["pre_admission", "admission", "resource_matching", "runtime_binding", "execution", "verification", "projection", "evidence", "persistence", "observability", "query", "write_verification", "reconciliation"]
        },
        "recovery_hint": {
          "type": "string",
          "minLength": 1
        },
        "attribution": {
          "type": "string",
          "enum": ["capability", "input", "runtime", "site", "evidence", "unknown"]
        }
      }
    },
    "post_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "status", "summary", "consumer_boundary"],
      "properties": {
        "schema_version": {
          "const": "webenvoy.post-check-result.v0"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "blocked", "not_run"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "attribution": {
          "type": "string",
          "enum": ["capability", "input", "runtime", "site", "evidence", "unknown"]
        },
        "recovery_hint": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "consumer_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "retention_state": {
      "type": "string",
      "enum": ["active", "summary_only", "expired", "redacted", "access_denied", "deleted_by_policy"]
    }
  }
}
